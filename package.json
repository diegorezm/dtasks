{
	"name": "dtask",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"@types/node": "^22.13.14",
			"@cloudflare/workers-types": "^4.20251213.0",
			"alchemy": "^0.87.0",
			"wrangler": "^4.54.0",
			"lucide-react": "^0.546.0",
			"next-themes": "^0.4.6",
			"react": "^19.2.3",
			"react-dom": "^19.2.3",
			"sonner": "^2.0.5",
			"tailwindcss": "^4.1.18",
			"@libsql/client": "0.15.15",
			"libsql": "0.5.22",
			"@types/react": "^19.2.10",
			"@types/react-dom": "^19.2.3"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @dtask/db db:push",
		"db:generate": "turbo -F @dtask/db db:generate",
		"ui:add": "bunx shadcn@latest add --cwd packages/ui",
		"deploy": "turbo -F @dtask/infra deploy",
		"destroy": "turbo -F @dtask/infra destroy",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@dtask/env": "workspace:*",
		"dotenv": "^17.3.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@cloudflare/workers-types": "^4.20260317.1",
		"@dtask/config": "workspace:*",
		"@types/node": "^22.19.15",
		"turbo": "^2.8.20",
		"typescript": "^5.9.3"
	},
	"packageManager": "bun@1.3.5"
}
